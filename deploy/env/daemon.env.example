# Copy to /etc/cs-storage/daemon.env and fill node-specific values outside git.
CS_DAEMON_SOCKET=/run/cs-storage.sock
CS_ROOT_DIR=/mnt/cs_storage/vols
CS_SERVER_URL=http://cs-storage-server.example.test:18080
CS_NODE_ID=replace-with-hostname-or-node-id
CS_NODE_SECRET_KEY=change-me
CS_ENABLE_CHATTR=true
CS_RECOVER_MOUNTS=true
# Optional daemon-managed volumes kept ready before Docker asks for them.
# CS_MANAGED_VOLUMES=app:cs.mode=shared,cs.write=multi,cs.engine=sqlite,cs.crypt=false
# CS_MANAGED_ENSURE_INTERVAL=30s
CS_RCLONE_VFS_CACHE_MODE=writes
CS_RCLONE_VFS_WRITE_BACK=
CS_RCLONE_VFS_CACHE_MAX_SIZE=
CS_GOCRYPTFS_PASSWORD=change-me
# Shared multi-write defaults generated by the installer:
# CS_GLUSTER_REMOTE=server-node:/css_shared
# CS_LITEFS_HTTP_ADDR=:20202
# CS_LITEFS_LEASE_TYPE=static
# CS_LITEFS_ADVERTISE_URL=http://this-node.example.test:20202
#
# Consul-compatible coordinator example for real multi-node LiteFS elections:
# CS_LITEFS_LEASE_TYPE=consul
# CS_LITEFS_CONSUL_URL=http://cs-storage-server.example.test:18080
# CS_LITEFS_CONSUL_KEY=cs-storage/litefs/example-volume
# CS_LITEFS_CONSUL_TOKEN=change-me
# CS_LITEFS_CONSUL_TTL=10s
# CS_LITEFS_CONSUL_LOCK_DELAY=1s
# CS_LITEFS_HOSTNAME=replace-with-hostname-or-node-id
# CS_RCLONE_SYNC_INTERVAL=30s
# Backup example:
# CS_KOPIA_CONFIG_PATH=/etc/cs-storage/kopia.repository.config
# CS_KOPIA_PASSWORD_FILE=/etc/cs-storage/secrets/kopia_password
# CS_KOPIA_SNAPSHOT_INTERVAL=30s
# CS_KOPIA_POLICY_ARGS=--keep-latest=24 --keep-daily=7

# Every string key also supports KEY_FILE for Docker secrets, for example:
# CS_GOCRYPTFS_PASSWORD_FILE=/run/secrets/gocryptfs_password
