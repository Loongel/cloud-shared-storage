# Copy to /etc/cs-storage/server.env and fill secrets outside git.
CS_SERVER_ADDR=:18080
CS_NODE_SECRET_KEY=change-me
CS_BACKEND_URL=https://webdav.example.test/dav/
# Public gateway URL returned to nodes from /auth.
# CS_PUBLIC_URL=https://cs-storage-server.example.test:18080
# Prefer CS_BACKEND_AUTH_HEADER from a secret manager in production.
# CS_BACKEND_AUTH_HEADER=Basic base64-user-pass
# CS_BACKEND_USER=
# CS_BACKEND_PASSWORD=
CS_TOKEN_TTL=12h
CS_SANDBOX_PREFIX=/nodes
CS_KV_PATH=/var/lib/cs-storage/gateway-kv.json
# Optional Consul-compatible token for LiteFS clients; keep secret outside git.
# CS_COORDINATOR_TOKEN=change-me

# Every string key also supports KEY_FILE for Docker secrets, for example:
# CS_BACKEND_PASSWORD_FILE=/run/secrets/backend_password
